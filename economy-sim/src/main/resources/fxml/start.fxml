<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.economysim.StartController"
      alignment="CENTER" spacing="20"
      style="-fx-background-color: #1a1a2e; -fx-padding: 60;">

    <Label text="AGE OF SAIL" style="-fx-font-size: 36px; -fx-text-fill: #e2b96f; -fx-font-weight: bold;"/>
    <Label text="Economy Sim" style="-fx-font-size: 16px; -fx-text-fill: #888888;"/>

    <VBox spacing="12" alignment="CENTER" style="-fx-padding: 40 0 0 0;">
        <Button fx:id="newGameBtn" text="New Game" onAction="#handleNewGame"
                style="-fx-background-color: #0f3460; -fx-text-fill: #e2b96f; -fx-font-size: 14px; -fx-padding: 10 40; -fx-border-color: #e2b96f; -fx-border-width: 1; -fx-cursor: hand;"/>
        <Button fx:id="loadGameBtn" text="Load Game" onAction="#handleLoadGame"
                style="-fx-background-color: #0f3460; -fx-text-fill: #e2e2e2; -fx-font-size: 14px; -fx-padding: 10 40; -fx-border-color: #378ADD; -fx-border-width: 1; -fx-cursor: hand;"/>
    </VBox>

    <Label fx:id="messageLabel" style="-fx-text-fill: #e07b54; -fx-font-size: 12px;"/>

</VBox>
